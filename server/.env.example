# ai-mood-pet server config
# Copy to .env, fill required, never commit.

# --- service ---
PORT=8350
LOG_LEVEL=INFO

# --- auth ---
# Bearer-токен в hello-WS-сообщении. Сгенерируй своим OS:
#   python -c "import secrets; print(secrets.token_hex(24))"
AUTH_TOKEN=

# --- LLM provider (Gemini primary) ---
# Получить ключ: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Опционально: для cloud_lite-vision модели нужны multimodal-capabilities.
# gemini-2.5-flash-lite multimodal — OK.

# --- STT (Gemini audio input — основной) ---
# Используется тот же GOOGLE_API_KEY. Если нужен OpenAI Whisper-fallback
# (после получения project-access), заполни:
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1

# --- TTS ---
# edge-tts через Microsoft Cognitive Services API (бесплатно, anonymous).
# Ничего настраивать не нужно — встроено.
TTS_BASE_VOICE=ru-RU-DmitryNeural

# --- персонажи ---
# Path к директории character JSON-spec'ов (см. server/characters/).
CHARACTERS_DIR=./characters
DEFAULT_CHARACTER=baby_robot

# --- история ---
# 5 пар = 5 user-msg + 5 assistant-msg. Локально in-memory (если 0)
# или SQLite (если задать путь).
HISTORY_PAIRS=5
HISTORY_DB_PATH=

# --- rate-limit (на будущее) ---
# Максимум сообщений от одного IP в минуту. 0 = выключено.
# TODO: реально пока не реализован, нужен slowapi или middleware. v0.2.
RATE_LIMIT_PER_MIN=60

# --- security middleware ---
# Список разрешённых Host header'ов (CSV). Для prod укажи свой домен.
# Дефолт "*" подходит только для dev на localhost.
ALLOWED_HOSTS=*

# CORS — список origin'ов которым разрешены cross-origin запросы.
# Пусто = блокирует все. "*" — только для dev.
CORS_ORIGINS=

# --- AGPL §13 compliance ---
# Если форкнул и хостишь модифицированную версию — обнови на свой репо.
# Сервер шлёт этот URL в каждом ответе как X-Source-URL header.
AGPL_SOURCE_URL=https://github.com/jetmil/ai-mood-pet
